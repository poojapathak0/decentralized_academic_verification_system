{
  "name": "academic-credentials-verification",
  "private": true,
  "version": "0.1.0",
  "type": "commonjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "compile:contracts": "cross-env TS_NODE_PROJECT=tsconfig.hardhat.json hardhat compile",
    "test:contracts": "cross-env TS_NODE_PROJECT=tsconfig.hardhat.json hardhat test",
    "node:contracts": "cross-env TS_NODE_PROJECT=tsconfig.hardhat.json hardhat node",
    "deploy:hardhat": "cross-env TS_NODE_PROJECT=tsconfig.hardhat.json hardhat run scripts/deploy.ts --network hardhat",
    "deploy:local": "cross-env TS_NODE_PROJECT=tsconfig.hardhat.json hardhat run scripts/deploy.ts --network localhost",
    "deploy:amoy": "cross-env TS_NODE_PROJECT=tsconfig.hardhat.json hardhat run scripts/deploy.ts --network amoy"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.0.5",
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-dropdown-menu": "^2.0.5",
    "@radix-ui/react-popover": "^1.0.7",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-tabs": "^1.0.4",
    "axios": "^1.16.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "ethers": "^6.16.0",
    "framer-motion": "^10.18.0",
    "jsqr": "^1.4.0",
    "lucide-react": "^0.292.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^6.30.3",
    "tailwind-merge": "^2.2.0",
    "viem": "^2.51.3",
    "wagmi": "^3.6.16",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "tailwindcss": "^3.4.0",
    "@openzeppelin/contracts": "^5.0.2",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "chai": "^4.5.0",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.5",
    "hardhat": "^2.28.6",
    "postcss": "^8.4.32",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  }
}
