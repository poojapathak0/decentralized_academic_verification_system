{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "types": ["node", "mocha", "chai", "hardhat"],
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": ["hardhat.config.ts", "scripts/**/*.ts", "test/**/*.ts", "contracts/**/*.sol"],
  "exclude": ["dist", "build", "cache", "artifacts", "typechain-types", "node_modules", "src"]
}